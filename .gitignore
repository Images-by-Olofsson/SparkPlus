# =============================================================
# SparkPlus Repository - .gitignore
# =============================================================

# --- OS generated files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# --- Node / npm (if applicable) ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Sensitive / Private ---
*.env
*.env.local
*.env.*.local
secrets/
credentials/

# --- Build artifacts ---
*.tmp
*.log
*.bak

# --- Other/experiments (keep .gitkeep but ignore contents) ---
Other/experiments/
Other/notes.md
!Other/.gitkeep
!Other/README.md
